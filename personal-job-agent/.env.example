# ================================================================
# Personal AI Job Agent — Environment Configuration
# Copy this to .env and fill in your values:
#   cp .env.example .env
# Then edit .env with your real API keys.
# ================================================================

# ── Application ──────────────────────────────────────────────────
APP_NAME=Personal AI Job Agent
DEBUG=false
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-a-long-random-secret-key-at-least-32-chars

# ── PostgreSQL ───────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=job_agent
# These URLs are overridden by docker-compose for container networking
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/job_agent
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/job_agent

# ── Redis / Celery ───────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Vector Store (Qdrant) ────────────────────────────────────────
QDRANT_URL=http://localhost:6333
ENABLE_QDRANT=true

# ── Document Store (MinIO / S3-compatible) ───────────────────────
# MINIO_ENDPOINT is "host:port" with NO http:// prefix
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET_RESUMES=resumes
MINIO_SECURE=false
ENABLE_MINIO=true

# ── LLM APIs — add at least one ─────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-your-key-here
OPENAI_API_KEY=sk-your-key-here
LLM_PRIMARY_PROVIDER=anthropic
LLM_PRIMARY_MODEL=claude-sonnet-4-6
LLM_FAST_MODEL=claude-haiku-4-5-20251001
LLM_FALLBACK_PROVIDER=openai
LLM_FALLBACK_MODEL=gpt-4o-mini
LLM_MAX_TOKENS=2048
LLM_TEMPERATURE=0.3
ENABLE_LLM=true

# ── Embeddings (runs locally, no API key needed) ─────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ── Email Notifications (optional) ──────────────────────────────
ENABLE_EMAIL_NOTIFICATIONS=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=your-email@gmail.com
NOTIFICATION_EMAIL=your-email@gmail.com

# ── Scraping (ethical defaults) ──────────────────────────────────
SCRAPER_DOWNLOAD_DELAY=2.0
SCRAPER_MAX_CONCURRENT=4
SCRAPER_RESPECT_ROBOTS=true

# ── Job Matching ─────────────────────────────────────────────────
MATCH_SCORE_THRESHOLD=50
HIGH_MATCH_THRESHOLD=75

# ── Celery Beat ──────────────────────────────────────────────────
BEAT_SCHEDULE_FILE=/app/beat/celerybeat-schedule

# ── Flower Monitoring ────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin
